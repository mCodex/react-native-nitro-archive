{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["archive"],
  "ios": { "iosModuleName": "NitroArchive" },
  "android": { "androidNamespace": ["archive"], "androidCxxLibName": "NitroArchive" },
  "autolinking": {
    "ArchiveModule": {
      "ios": { "language": "swift", "implementationClassName": "HybridArchiveModule" },
      "android": { "language": "kotlin", "implementationClassName": "HybridArchiveModule" }
    }
  },
  "ignorePaths": ["**/node_modules/**", "**/lib/**", "**/example/**", "**/tests/**"],
  "gitAttributesGeneratedFlag": true
}
